generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessions             Session[]
  accounts             Account[]
  categories           Category[]
  transactions         Transaction[]
  creditCardStatements CreditCardStatement[]
  dashboard            Dashboard?
  recurringRules       RecurringRule[]
  goals                Goal[]
  forecastSnapshots    ForecastSnapshot[]
  scoreSnapshots       FinancialScoreSnapshot[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

enum AccountType {
  WALLET
  CHECKING
  SAVINGS
  CREDIT_CARD
  INVESTMENT
  OTHER

  @@map("account_type")
}

enum CategoryType {
  INCOME
  EXPENSE

  @@map("category_type")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER

  @@map("transaction_type")
}

model Account {
  id                  String      @id @default(cuid())
  userId              String      @map("user_id")
  name                String
  type                AccountType
  initialBalance      Int         @default(0) @map("initial_balance")
  creditLimit         Int?        @map("credit_limit")
  statementClosingDay Int?        @map("statement_closing_day")
  statementDueDay     Int?        @map("statement_due_day")
  color               String?
  icon                String?
  isArchived          Boolean     @default(false) @map("is_archived")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions         Transaction[]
  creditCardStatements CreditCardStatement[]
  recurringRules       RecurringRule[]
  goals                Goal[]

  @@index([userId])
  @@map("accounts")
}

model Category {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  name      String
  type      CategoryType
  icon      String?
  color     String?
  parentId  String?      @map("parent_id")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent         Category?       @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children       Category[]      @relation("CategoryHierarchy")
  transactions   Transaction[]
  recurringRules RecurringRule[]
  goals          Goal[]

  @@index([userId])
  @@index([parentId])
  @@map("categories")
}

model Transaction {
  id                    String          @id @default(cuid())
  userId                String          @map("user_id")
  accountId             String          @map("account_id")
  categoryId            String?         @map("category_id")
  creditCardStatementId String?         @map("credit_card_statement_id")
  type                  TransactionType
  amount                Int
  description           String
  notes                 String?
  date                  DateTime
  transferId            String?         @map("transfer_id")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  account             Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category            Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  creditCardStatement CreditCardStatement? @relation("CreditCardStatementTransactions", fields: [creditCardStatementId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
  @@index([creditCardStatementId])
  @@index([date])
  @@index([transferId])
  @@map("transactions")
}

enum CreditCardStatementStatus {
  OPEN
  CLOSED
  PAID
  OVERDUE

  @@map("credit_card_statement_status")
}

model CreditCardStatement {
  id          String                    @id @default(cuid())
  userId      String                    @map("user_id")
  accountId   String                    @map("account_id")
  periodStart DateTime                  @map("period_start")
  periodEnd   DateTime                  @map("period_end")
  closingDate DateTime                  @map("closing_date")
  dueDate     DateTime                  @map("due_date")
  totalAmount Int                       @default(0) @map("total_amount")
  paidAmount  Int                       @default(0) @map("paid_amount")
  status      CreditCardStatementStatus @default(OPEN)
  createdAt   DateTime                  @default(now()) @map("created_at")
  updatedAt   DateTime                  @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions Transaction[] @relation("CreditCardStatementTransactions")

  @@unique([accountId, periodStart])
  @@index([userId])
  @@index([accountId])
  @@index([dueDate])
  @@map("credit_card_statements")
}

model Dashboard {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgets DashboardWidget[]

  @@map("dashboards")
}

model DashboardWidget {
  id          String   @id @default(cuid())
  dashboardId String   @map("dashboard_id")
  type        String
  config      Json     @default("{}")
  x           Int      @default(0)
  y           Int      @default(0)
  w           Int      @default(6)
  h           Int      @default(4)
  createdAt   DateTime @default(now()) @map("created_at")

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId])
  @@map("dashboard_widgets")
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY

  @@map("recurring_frequency")
}

model RecurringRule {
  id          String             @id @default(cuid())
  userId      String             @map("user_id")
  accountId   String             @map("account_id")
  categoryId  String?            @map("category_id")
  type        TransactionType
  amount      Int
  description String
  notes       String?
  frequency   RecurringFrequency
  dayOfMonth  Int?               @map("day_of_month")
  dayOfWeek   Int?               @map("day_of_week")
  startDate   DateTime           @map("start_date")
  endDate     DateTime?          @map("end_date")
  isActive    Boolean            @default(true) @map("is_active")
  lastApplied DateTime?          @map("last_applied")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  logs     RecurringLog[]

  @@index([userId])
  @@map("recurring_rules")
}

model RecurringLog {
  id              String   @id @default(cuid())
  recurringRuleId String   @map("recurring_rule_id")
  transactionId   String?  @map("transaction_id")
  appliedDate     DateTime @map("applied_date")
  status          String
  error           String?
  createdAt       DateTime @default(now()) @map("created_at")

  rule RecurringRule @relation(fields: [recurringRuleId], references: [id], onDelete: Cascade)

  @@index([recurringRuleId])
  @@map("recurring_logs")
}

enum GoalMetric {
  SAVING
  EXPENSE_LIMIT
  INCOME_TARGET
  ACCOUNT_LIMIT

  @@map("goal_metric")
}

enum GoalScopeType {
  GLOBAL
  CATEGORY
  ACCOUNT

  @@map("goal_scope_type")
}

enum GoalPeriod {
  MONTHLY
  YEARLY

  @@map("goal_period")
}

enum GoalStatus {
  ON_TRACK
  WARNING
  AT_RISK
  ACHIEVED
  EXCEEDED

  @@map("goal_status")
}

model Goal {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  name           String
  description    String?
  metric         GoalMetric
  scopeType      GoalScopeType @default(GLOBAL) @map("scope_type")
  categoryId     String?       @map("category_id")
  accountId      String?       @map("account_id")
  targetAmount   Int           @map("target_amount")
  period         GoalPeriod    @default(MONTHLY)
  warningPercent Int           @default(80) @map("warning_percent")
  dangerPercent  Int           @default(95) @map("danger_percent")
  isActive       Boolean       @default(true) @map("is_active")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  account   Account?       @relation(fields: [accountId], references: [id], onDelete: SetNull)
  snapshots GoalSnapshot[]

  @@index([userId])
  @@map("goals")
}

model GoalSnapshot {
  id              String     @id @default(cuid())
  goalId          String     @map("goal_id")
  periodStart     DateTime   @map("period_start")
  periodEnd       DateTime   @map("period_end")
  actualAmount    Int        @map("actual_amount")
  projectedAmount Int        @map("projected_amount")
  progressPercent Int        @map("progress_percent")
  status          GoalStatus
  calculatedAt    DateTime   @default(now()) @map("calculated_at")

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, periodStart])
  @@index([goalId])
  @@map("goal_snapshots")
}

enum ForecastRiskLevel {
  LOW
  MEDIUM
  HIGH

  @@map("forecast_risk_level")
}

model ForecastSnapshot {
  id                         String            @id @default(cuid())
  userId                     String            @map("user_id")
  periodStart                DateTime          @map("period_start")
  periodEnd                  DateTime          @map("period_end")
  referenceDate              DateTime          @map("reference_date")
  actualIncome               Int               @map("actual_income")
  actualExpenses             Int               @map("actual_expenses")
  projectedRecurringIncome   Int               @map("projected_recurring_income")
  projectedRecurringExpenses Int               @map("projected_recurring_expenses")
  projectedVariableIncome    Int               @map("projected_variable_income")
  projectedVariableExpenses  Int               @map("projected_variable_expenses")
  predictedBalance           Int               @map("predicted_balance")
  riskLevel                  ForecastRiskLevel @map("risk_level")
  assumptions                Json
  calculatedAt               DateTime          @default(now()) @map("calculated_at")
  staleAt                    DateTime?         @map("stale_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodStart])
  @@index([userId])
  @@map("forecast_snapshots")
}

enum FinancialScoreStatus {
  CRITICAL
  ATTENTION
  GOOD
  EXCELLENT

  @@map("financial_score_status")
}

model FinancialScoreSnapshot {
  id           String               @id @default(cuid())
  userId       String               @map("user_id")
  periodStart  DateTime             @map("period_start")
  periodEnd    DateTime             @map("period_end")
  score        Int
  status       FinancialScoreStatus
  factors      Json
  insights     Json
  calculatedAt DateTime             @default(now()) @map("calculated_at")
  staleAt      DateTime?            @map("stale_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodStart])
  @@index([userId])
  @@map("financial_score_snapshots")
}
